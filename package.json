{
    "name": "minimal-intelligent-kuota-extension",
    "displayName": "Minimal Intelligent Kuota Extension",
    "description": "M.I.K.E. — Zero-telemetry AI quota tracker for your status bar",

    "version": "2.0.0",

    "publisher": "mdzie",
    "icon": "MIKE-Quota.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/mdziejma/Minimal_Intelligent_Kuota_Extension.git"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "mikeQuota.refresh",
                "title": "Refresh Quota"
            },
            {
                "command": "mikeQuota.showPlot",
                "title": "Plot Quota Usage"
            },
            {
                "command": "mikeQuota.debugHistory",
                "title": "Debug Quota History"
            },
            {
                "command": "mikeQuota.clearHistory",
                "title": "Clear Quota History"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
        "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "package": "vsce package && mkdir -p binaries && mv *.vsix binaries/",
        "compile-build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
        "deploy": "ovsx publish",
        "test": "mocha -r ts-node/register test/**/*.test.ts"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/chai": "^4.3.5",
        "@types/mocha": "^10.0.10",
        "@types/node": "16.x",
        "@types/vscode": "^1.75.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "chai": "^4.3.7",
        "esbuild": "^0.17.11",
        "eslint": "^10.0.2",
        "mocha": "^11.7.5",
        "ovsx": "^0.10.9",
        "ts-node": "^10.9.2",
        "typescript": "^4.9.5",
        "typescript-eslint": "^8.56.1"
    },
    "license": "MIT"
}